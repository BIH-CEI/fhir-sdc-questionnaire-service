# Single source of truth for "our" versions.
#
# - FORM_MANAGER_VERSION  — this repo's runtime SemVer (HAPI image + sidecar).
#                           Bump on functionality changes.
# - PRO_LIBRARY_VERSION   — bundled BIH-CEI/pro-library content version.
#                           Bump when shipping new content into the image.
#
# Deliberately excludes MII PRO (and any other upstream IG): those are
# external content with their own cadence. They live in Dockerfile.form-manager
# as build-args with sensible defaults that can be overridden per-build.

FORM_MANAGER_VERSION=0.1.0
PRO_LIBRARY_VERSION=0.1.3
